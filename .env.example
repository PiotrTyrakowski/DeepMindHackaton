# ─────────────────────────────────────────────────────────────────────────────
#  .env.example — copy to .env and fill in your credentials
#  NEVER commit .env to git!
# ─────────────────────────────────────────────────────────────────────────────

# ── Apify ─────────────────────────────────────────────────────────────────────
# Get your token at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Gemini Live (voice agent) ──────────────────────────────────────────
# Create a key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Anthropic Claude (website generation) ────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio (outbound calls + SMS) ─────────────────────────────────────────────
# Find these at: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# A Twilio phone number with Voice + SMS capabilities (E.164 format)
TWILIO_PHONE_NUMBER=+12025551234

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# PUBLIC_URL must be reachable by Twilio (it POSTs to your server on answer).
# For local development, use ngrok:
#   ngrok http 8000
# Then set PUBLIC_URL to the https:// URL ngrok gives you.
PUBLIC_URL=https://your-subdomain.ngrok-free.app

# ── Storage ───────────────────────────────────────────────────────────────────
# Directory where generated HTML websites are saved
WEBSITES_DIR=./generated_websites
